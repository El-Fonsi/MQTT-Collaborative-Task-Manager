# Server
PORT=4000
JWT_SECRET=change-this-to-a-random-secret-string

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/taskboard

# MQTT Broker
MQTT_URL=mqtts://your-cluster-id.s1.eu.hivemq.cloud:8883
MQTT_USERNAME=taskboard-server
MQTT_PASSWORD=your-broker-password

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Server public URL (for absolute avatar URLs)
# SERVER_URL=http://localhost:4000
